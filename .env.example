# ARGUS FastAPI
APP_NAME=ARGUS
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["*"]

# Bright Data MCP, Web Unlocker, and SERP API
BRIGHT_DATA_MCP_URL=https://mcp.brightdata.com/mcp
BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_SERP_ENDPOINT=https://api.brightdata.com/request
BRIGHT_DATA_SERP_ZONE=
BRIGHT_DATA_WEB_UNLOCKER_ZONE=
BRIGHT_DATA_COUNTRY=us
MAX_SERP_QUERIES=6
MAX_RESULTS_PER_QUERY=5
REQUEST_TIMEOUT_SECONDS=25

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=chevalblanc/gpt-4o-mini

# Cognee persistent threat memory
COGNEE_ENABLED=true
COGNEE_DATASET=argus-threat-memory
LOCAL_MEMORY_PATH=backend/data/threat_memory.jsonl

# TriggerWare.ai webhook alerts
TRIGGERWARE_WEBHOOK_URL=
TRIGGERWARE_SECRET=

